rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only read/write their own files
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
